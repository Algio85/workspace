{
  "name": "tao-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/portfolio"
  ],
  "overrides": {
    "kleur": "^4.1.5"
  },
  "scripts": {
    "build:tao": "npm run build --workspace=packages/tao",
